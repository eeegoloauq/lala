  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>Lala</name>
  <summary>Self-hosted voice &amp; video chat</summary>
  <description>
    <p>Self-hosted voice and video chat built on LiveKit (WebRTC SFU). Like Mumble or Discord, but yours.</p>
    <p>Features E2EE for password-protected rooms, screen sharing with system audio, configurable audio quality, 6 themes, and room administration.</p>
  </description>
  <launchable type="desktop-id">lala-desktop.desktop</launchable>
  <url type="homepage">https://github.com/eeegoloauq/lala</url>
  <url type="bugtracker">https://github.com/eeegoloauq/lala/issues</url>
  <url type="donation">https://github.com/eeegoloauq/lala#donate</url>
