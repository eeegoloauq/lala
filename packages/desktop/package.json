{
    "name": "lala-desktop",
    "version": "0.0.2",
    "description": "Lala Desktop Client — Self-hosted voice & video chat",
    "author": {
        "name": "Egor Solovyov",
        "email": "noreply@example.com"
    },
    "repository": "https://github.com/eeegoloauq/lala",
    "homepage": "https://github.com/eeegoloauq/lala",
    "license": "MIT",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "generate-icons": "node scripts/generate-icons.js",
        "prebuild": "npm run generate-icons",
        "build:linux": "electron-builder --linux",
        "build:win": "electron-builder --win",
        "build:mac": "electron-builder --mac",
        "build": "electron-builder --linux --win",
        "publish:win": "electron-builder --win --publish always",
        "publish:linux": "electron-builder --linux --publish always"
    },
    "dependencies": {
        "electron-updater": "^6.3.9"
    },
    "devDependencies": {
        "electron": "^40.6.1",
        "electron-builder": "^25.1.8",
        "sharp": "^0.34.5"
    }
}
