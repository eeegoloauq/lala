# Lala Environment Configuration — copy to .env and fill in real values

# LiveKit connection (Media/Signaling)
LIVEKIT_URL=wss://rtc.example.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Server public IP (used for WebRTC ICE candidates and LiveKit node-ip)
NODE_IP=your_server_ip

# TURN domain (must resolve to the server)
LIVEKIT_DOMAIN=rtc.example.com

# Public URL for the UI (for metadata/links)
PUBLIC_UI_URL=https://lala.example.com

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://lala.example.com,http://localhost:3000

# API server
API_PORT=3001

# Web server (dev)
WEB_PORT=3000

# LiveKit server
LIVEKIT_PORT=7880

# Content Security Policy — extra connect-src origins (optional, for hardening)
# Default: wss: ws: (allows any WebSocket — works out of the box)
# Tighten to your LiveKit domain for security:
#CSP_CONNECT_SRC=wss://rtc.example.com
