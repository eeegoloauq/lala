# Custom rpkg macros for Copr srpm generation (used by lala-desktop.spec).

function lala_version {
    sed -n 's/^[[:space:]]*"version":[[:space:]]*"\([^"]*\)".*/\1/p' \
        packages/desktop/package.json | head -n1 | tr -d '\n'
}

function lala_release {
    # Monotonic release so every push to main produces an upgradeable NVR
    # even when package.json version is unchanged.
    printf '%s.git%s' "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}
